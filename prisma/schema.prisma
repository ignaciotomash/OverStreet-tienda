generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Categoria {
  indumentaria
  tecnologia
  perfumeria
}

model Producto {
  id               String    @id
  nombre           String
  precio           Int
  categoria        Categoria
  subcategoria     String
  descripcion      String
  descripcionLarga String    @map("descripcion_larga")
  detalles         Json
  talles           Json?
  colores          Json?
  stockUnidades    Int?      @map("stock_unidades")
  imagenes         Json      @default("[]")
  agotado          Boolean   @default(false)
  vistas           Int       @default(0)
  creadoEn         DateTime  @default(now()) @map("creado_en")
  actualizadoEn    DateTime  @updatedAt @map("actualizado_en")

  @@map("productos")
}
